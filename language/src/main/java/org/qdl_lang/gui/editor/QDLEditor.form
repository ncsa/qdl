<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="org.qdl_lang.gui.editor.QDLEditor">
  <grid id="27dc6" binding="mainPanel" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="0" left="0" bottom="0" right="0"/>
    <constraints>
      <xy x="20" y="20" width="804" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <scrollpane id="b63a5" class="org.fife.ui.rtextarea.RTextScrollPane" binding="RTextScrollPane1" custom-create="true" default-binding="true">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="0" indent="0" use-parent-layout="false">
            <minimum-size width="800" height="250"/>
          </grid>
        </constraints>
        <properties>
          <foldIndicatorEnabled value="false"/>
          <font name="DialogInput" size="14" style="1"/>
          <lineNumbersEnabled value="false"/>
        </properties>
        <border type="none"/>
        <children>
          <component id="6462d" class="org.fife.ui.rsyntaxtextarea.RSyntaxTextArea" binding="input" custom-create="true">
            <constraints/>
            <properties>
              <closeCurlyBraces value="false"/>
              <codeFoldingEnabled value="true"/>
              <columns value="80"/>
              <font name="DialogInput" size="14" style="1"/>
              <minimumSize width="800" height="250"/>
              <rows value="20"/>
              <syntaxEditingStyle value="text/qdl"/>
            </properties>
          </component>
        </children>
      </scrollpane>
    </children>
  </grid>
</form>
