#! /usr/bin/env -S qdl-run

/*
  Test batch modes.
*/
⊨ 0 < size(args()) : 'Missing connection ini';

  db ≔ j_load('db');
cfg. ≔ interpret(file_read(args().0));
db#connect(cfg.);

// stems and lists
⊨db#sql_to_qdl(to_json({'a':1}), db#qdl_types.'json').'a' ≡ 1 : 'conversion of QDL stem -> input form string failed';
 z. := db#sql_to_qdl(to_json(['a',1]), db#qdl_types.'json');
⊨ z.0 ≡ 'a' ∧ z.1 ≡ 1 : 'conversion of JSON list -> QDL list  failed';
// dates
d := date_iso();
d ≔ date_iso();
dd ≔ date_ms(d);
⊨db#sql_to_qdl(dd, db#qdl_types.'date') ≡ d : 'conversion of QDL date -> string failed'; // returns a string
⊨db#sql_to_qdl(dd, db#qdl_types.'string') ≡ dd: 'conversion of BigInt -> BigInt failed'; // should do nothing


// sets
⊨ db#sql_to_qdl('[1,2,3,"a"]', db#qdl_types.'json_set') == {'a',1,2,3} : 'conversion of JSON string -> QDL set failed';
⊨ db#sql_to_qdl('{1,2,3,\'a\'}', db#qdl_types.'input_form') == {'a',1,2,3} == {'a',1,2,3} : 'conversion of JSON string -> QDL set failed';
