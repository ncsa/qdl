#! /usr/bin/env -S qdl-run

/*
    Basic creation test with qdl types
*/
⊨ 0 < size(args()) : 'Missing connection ini';
debugger(10);
  db ≔ j_load('db');
cfg. ≔ interpret(file_read(args().0));
db#connect(cfg.);
numeric_digits(20);

                a. ≔ rr(true,true);
a.'timestamp_long' ≔ date_iso();  // For testing QDL conversion, where the SQL column type is long, but QDL is a date.
               qt. ≔ {'blob_0':db#qdl_types.'json',
                       'set_0':db#qdl_types.'input_form',
                       'timestamp_long':db#qdl_types.'date'
                       };
db#qdl_create('db_test',a., qt.);
c. ≔ db#read('select * from db_test where varchar_128=?',[a.'varchar_128'], qt.).0;
⊨ 1 == db#execute('delete from db_test where varchar_128=?',[a.'varchar_128']) : 'Could not delete object with id \'' + a.'varchar_128' + '\'';
   return(check_stem(a., c., true));
