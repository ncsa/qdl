#! /usr/bin/env -S qdl-run

/*
    Basic creation test. So no qdl types just each SQL type is done with
    no QDL -> SQL conversions.

    Note that date, time and timestamp columns are set in the database
    and sending them is ignored, so we don't set them here.
*/
⊨ 0 < size(args()) : 'Missing connection ini';

  db ≔ j_load('db');
cfg. ≔ interpret(file_read(args().0));
db#connect(cfg.);
numeric_digits(20);
random_string := 'ANxX505vlEUAiuaMaI-jATBIl7qmrlLO_547yNSYGZYwEdFqOhpbrY3uCU3bJtZK';
            a.'bit_0' ≔ true;
           a.'blob_0' ≔ random_string;
        a.'boolean_0' ≔ false;
         a.'double_0' ≔ 54321.987654321;
          a.'float_0' ≔ -4.25;
        a.'integer_0' ≔ 2^11;
        a.'numeric_0' ≔ pi();            // precision set high
            a.'set_0' ≔ 'This is not a set';     // should be a string if no QDL types
       a.'smallint_0' ≔ 5;
           a.'text_0' ≔ 'I could see that, if not actually disgruntled, he was far from being gruntled.';
   a.'timestamp_long' ≔ date_ms();        // For testing QDL conversion, here we are not and the QSL column type is long
        a.'tinyint_0' ≔ -2;
      a.'varchar_128' ≔ 'id-'+random_string(4);   // unique identifier

db#create('oauth2.db_test',a.);
c. ≔ db#query('select * from oauth2.db_test where varchar_128=?',[a.'varchar_128']).0;
out. ≔ a. ≡ c.;
db#execute('delete from oauth2.db_test where varchar_128=?',[a.'varchar_128']);
ok ≔  ⊗∧⊙out.;
  if[¬ok]
then[
    bad_c.≔ (¬out.)⌆c.; // received
    ⊨ ok : bad_c.; // pass back the columns that don't match in the check.
];
return(ok);
