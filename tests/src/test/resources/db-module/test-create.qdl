#! /usr/bin/env -S qdl-run

/*
  Test batch modes.
*/
⊨ 0 < size(args()) : 'Missing connection ini';

  db ≔ j_load('db');
cfg. ≔ interpret(file_read(args().0));
db#connect(cfg.);
numeric_digits(20);
ids.:= 'a-'+n(16);
stmt := 'insert into xxx (id,name) values (?,?)';
out. := db#batch_execute(stmt, [['a-0',random_string(20)],
                         ['a-1',random_string(20)],
                         ['a-2',random_string(20)],
                         ['a-3',random_string(20)]]);
⊨⊗∧⊙1≡out. : 'Insert failed for simple list:' + to_string(out.);

// next round, with a stem
out. := db#batch_execute(stmt, {'a':['a-4',random_string(20)],
                          'b':['a-5',random_string(20)],
                         'c':['a-6',random_string(20)],
                         'd':['a-7',random_string(20)]});
⊨⊗∧⊙{'a':1, 'b':1, 'c':1, 'd':1}≡out. : 'Insert failed for stem:' + to_string(out.);

// next, with QDL conversions.
qq. := {'a':123,'b':{'c':234,'d':'SPQR'}};
c.1 := [12,1]; // is an SQL string, element 1 has type JSON

c.1 := [12,1]; // element 1 has type JSON
out. := db#batch_execute(stmt, [['a-8',qq.],
                         ['a-9',qq.],
                         ['a-10',qq.],
                         ['a-11',qq.]], c.);

⊨⊗∧⊙1≡out. : 'Insert failed for list with QDL conversions:' + to_string(out.);

// Finally, repeat for a stem argument.
out. := db#batch_execute(stmt, {
                          'a':['a-12',qq.],
                          'b':['a-13',qq.],
                          'c':['a-14',qq.],
                          'd':['a-15',qq.]}, c.);
⊨⊗∧⊙{'a':1, 'b':1, 'c':1, 'd':1}≡out. : 'Insert failed for stem with QDL:' + to_string(out.);

out. := db#batch_execute('delete from xxx where id=?',ids.);
